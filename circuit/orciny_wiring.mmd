flowchart TD
  %% Rev F — RP2040-only single-controller design
  %% NeoPixel data: RP2040 GP4 | Switches: A1/A2/A3 (GP27/GP28/GP29)
  %% See orciny_wiring_ascii.txt for detailed net and harness notes

  J801["J801\n5V Input (battery or supply)"]
  F801["F801\n3A Slow-Blow Fuse"]
  BRP["LP503562 #1\n3.7V 1200mAh\nRP2040 Battery J811"]
  BNEO["LP503562 #2\n3.7V 1200mAh\nNeoPixel Battery J812"]
  CNEO["U812 Adafruit 259\nNeoPixel Charger"]
  GND[GND_COMMON]

  RP["Feather RP2040\nPrimary Controller"]
  CORE["SK6812 NeoPixel Strip\n166 pixels Adafruit 4865\nFW 2A max guard rail"]
  PMFW["Prop-Maker FeatherWing\nLED MOSFET Outputs"]
  PMFWPWR["Prop-Maker PWR Enable\nGP10 held HIGH"]
  SWING["8-ch Servo FeatherWing\nPCA9685 at I2C 0x40"]

  SW1["SW1 A1(GP27) On/Off\nto GND"]
  SW2["SW2 A2(GP28) Previous\nto GND"]
  SW3["SW3 A3(GP29) Next\nto GND"]

  SP1["Spark Filament 1\nGP7 + R601 10Ω"]
  SP2["Spark Filament 2\nGP6 + R602 10Ω"]
  SP3["Spark Filament 3\nGP9 + R603 10Ω"]
  SP4["Spark Filament 4\nGP24 + R604 10Ω"]

  LED1["Beam LED CH1\n3-9W RGB leg 1"]
  LED2["Beam LED CH2\n3-9W RGB leg 2"]
  LED3["Beam LED CH3\n3-9W RGB leg 3"]

  PELTIER["Peltier Module\nQ9 GP8 MOSFET\nAuto: beam-follow + cooldown hold"]
  PUMP["Pump optional\nQ10 MOSFET\nGPIO unassigned in this rev"]

  SA["Servo A\nServoWing CH0"]
  SB["Servo B\nServoWing CH1"]

  J801 --> F801
  F801 -->|"+5V_BUS"| SWING
  F801 -->|"+5V_BUS"| PMFW
  F801 -->|"+5V_BUS"| PELTIER
  F801 -->|"+5V_BUS"| PUMP

  BRP -->|"RP2040_BAT"| RP
  BRP -->|"RP2040_BAT"| SP1
  BRP -->|"RP2040_BAT"| SP2
  BRP -->|"RP2040_BAT"| SP3
  BRP -->|"RP2040_BAT"| SP4

  CNEO --> BNEO
  BNEO -->|"+3V7_NEO"| CORE

  RP -->|"GP4 data"| CORE
  RP --- SW1
  RP --- SW2
  RP --- SW3
  RP -->|"GP7 PWM"| SP1
  RP -->|"GP6 PWM"| SP2
  RP -->|"GP9 PWM"| SP3
  RP -->|"GP24 PWM"| SP4
  RP -->|"GP11/12/13"| PMFW
  RP -->|"GP10 HIGH"| PMFWPWR
  RP -->|"GP8 auto ctl"| PELTIER
  RP -->|"I2C SDA/SCL"| SWING

  PMFW -->|"LED1 MOSFET"| LED1
  PMFW -->|"LED2 MOSFET"| LED2
  PMFW -->|"LED3 MOSFET"| LED3
  PMFWPWR --- PMFW
  SWING -->|"CH0"| SA
  SWING -->|"CH1"| SB

  GND --- RP
  GND --- BRP
  GND --- BNEO
  GND --- CNEO
  GND --- CORE
  GND --- SW1
  GND --- SW2
  GND --- SW3
  GND --- SP1
  GND --- SP2
  GND --- SP3
  GND --- SP4
  GND --- LED1
  GND --- LED2
  GND --- LED3
  GND --- PELTIER
  GND --- PUMP
  GND --- SWING
  GND --- SA
  GND --- SB
